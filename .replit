modules = ["nodejs-20", "swift-5.8", "web", "postgresql-16"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "API Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "iOS Build (unsigned IPA)"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd website && npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "API Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd website && npm run api"
waitForPort = 3001

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "iOS Build (unsigned IPA)"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd ios && bash build-unsigned.sh"

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3001

[deployment]
deploymentTarget = "vm"
build = ["bash", "-c", "cd website && npm install && npm run build"]
publicDir = "website/dist"
run = ["bash", "-c", "cd website && node server/index.js"]

[userenv]

[userenv.shared]
ADMIN_PASSWORD_HASH = "$2b$12$alU4QGknBlzCck80v3qgd.VACf.fbJ4DjSNtpbZIwQIER4EGWURG."
GITHUB_REPO = "leviidev/voxa"
