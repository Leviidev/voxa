{
  "name": "voxa-macos",
  "version": "0.1.0",
  "description": "Voxa Desktop App for macOS",
  "main": "main.js",
  "author": "Voxa",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --mac",
    "dist:dmg": "electron-builder --mac dmg"
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "lol.voxa.desktop",
    "productName": "Voxa",
    "publish": null,
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "assets/**"
    ],
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] },
        { "target": "zip", "arch": ["x64", "arm64"] }
      ],
      "category": "public.app-category.social-networking",
      "minimumSystemVersion": "13.0",
      "darkModeSupport": true
    },
    "dmg": {
      "title": "Voxa",
      "artifactName": "Voxa-${version}.dmg",
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        { "x": 150, "y": 185, "type": "file" },
        { "x": 390, "y": 185, "type": "link", "path": "/Applications" }
      ]
    }
  }
}
