{
  "name": "voxa-linux",
  "version": "0.1.0",
  "description": "Voxa Desktop App for Linux",
  "homepage": "https://voxa.lol",
  "main": "main.js",
  "author": {
    "name": "Voxa",
    "email": "hello@voxa.lol"
  },
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --linux",
    "dist:appimage": "electron-builder --linux AppImage"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "lol.voxa.desktop",
    "productName": "Voxa",
    "publish": null,
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "assets/**"
    ],
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] },
        { "target": "deb",      "arch": ["x64"] }
      ],
      "category": "Network",
      "icon": "assets/icon.png",
      "artifactName": "Voxa-${version}.${ext}",
      "maintainer": "Voxa <hello@voxa.lol>"
    },
    "deb": {
      "depends": ["libgtk-3-0", "libnotify4", "libnss3", "libxss1", "libxtst6", "xdg-utils"]
    }
  }
}
